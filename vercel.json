{
    "cleanUrls":  false,
    "trailingSlash":  false,
    "functions": {
        "api/platform.js": { "includeFiles": "lib/**" },
        "api/capture-livraison.js": { "includeFiles": "lib/**" },
        "api/paiement-livraison.js": { "includeFiles": "lib/**" },
        "api/cron-cleanup.js": { "includeFiles": "lib/**" },
        "api/turnstile-verify.js": { "includeFiles": "lib/**" }
    },
    "crons": [
        { "path": "/api/cron-cleanup", "schedule": "0 3 * * *" }
    ],
    "redirects": [
        { "source": "/(.*\\.sql)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.bat)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.ps1)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.txt)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.backup)", "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.env)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.log)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.key)",    "destination": "/404.html", "permanent": false },
        { "source": "/(.*\\.pem)",    "destination": "/404.html", "permanent": false },
        { "source": "/backups/(.*)",    "destination": "/404.html", "permanent": false },
        { "source": "/_archived/(.*)", "destination": "/404.html", "permanent": false },
        { "source": "/save/(.*)",      "destination": "/404.html", "permanent": false },
        { "source": "/lib/(.*)",       "destination": "/404.html", "permanent": false },
        { "source": "/BACKEND-(.*\\.md)",  "destination": "/404.html", "permanent": false },
        { "source": "/SECURITY-(.*\\.md)", "destination": "/404.html", "permanent": false },
        { "source": "/admin/admin-legacy.html", "destination": "/404.html", "permanent": false },
        { "source": "/admin-dashboard.html",    "destination": "/404.html", "permanent": false },
        { "source": "/test-login.html",         "destination": "/404.html", "permanent": false }
    ],
